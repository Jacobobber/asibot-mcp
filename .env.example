# Asibot MCP Server Configuration
# Copy to .env and fill in your values
# NOTE: Service credentials (GitHub, ZenDesk, etc.) are per-user,
# stored via the asibot_connect tool. Only server-wide settings go here.

# Server
ASIBOT_TRANSPORT=streamable-http
ASIBOT_PORT=8080
ASIBOT_HOST=0.0.0.0

# Microsoft 365 App Registration (server-wide, shared by all users)
# Users authenticate individually via SSO device code flow
ASIBOT_MS365_TENANT_ID=your-azure-tenant-id
ASIBOT_MS365_CLIENT_ID=your-app-client-id
ASIBOT_SHAREPOINT_SITE_URL=yourcompany.sharepoint.com
