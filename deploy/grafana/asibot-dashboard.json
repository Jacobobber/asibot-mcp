{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "uid": "asibot-overview",
  "title": "Asibot MCP Server",
  "description": "Operational dashboard for the Asibot MCP RAG agent server",
  "tags": ["asibot", "mcp"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(asibot_requests_total, service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100
    },
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum(rate(asibot_requests_total{service=~\"$service\"}[5m]))",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "sum(rate(asibot_requests_total{service=~\"$service\"}[5m])) by (service)",
          "legendFormat": "{{ service }}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum(rate(asibot_requests_total{service=~\"$service\", status!=\"ok\"}[5m]))",
          "legendFormat": "errors/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(asibot_requests_total{service=~\"$service\", status!=\"ok\"}[5m])) / sum(rate(asibot_requests_total{service=~\"$service\"}[5m])) * 100",
          "legendFormat": "error %",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Sessions",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 900 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "asibot_active_sessions",
          "legendFormat": "sessions",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Auth Failures",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "sum(rate(asibot_auth_failures_total[5m])) by (reason)",
          "legendFormat": "{{ reason }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101
    },
    {
      "id": 5,
      "title": "Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(asibot_request_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(asibot_request_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(asibot_request_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Per-Service Latency (p95)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "calcs": ["lastNotNull", "max"], "placement": "right" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(asibot_request_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le, service))",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Circuit Breaker",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102
    },
    {
      "id": 7,
      "title": "Circuit Breaker State per Service",
      "description": "0 = closed (healthy), 1 = half-open (probing), 2 = open (tripped)",
      "type": "state-timeline",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "HALF-OPEN", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "OPEN", "color": "red" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "showValue": "always",
        "rowHeight": 0.8,
        "mergeValues": true,
        "alignValue": "center"
      },
      "targets": [
        {
          "expr": "asibot_circuit_state",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Rate Limit Rejections",
      "description": "Requests rejected by rate limiting (status=rate_limited)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "sum(rate(asibot_requests_total{status=\"rate_limited\"}[5m])) by (service)",
          "legendFormat": "{{ service }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(asibot_requests_total{status=\"circuit_open\"}[5m])) by (service)",
          "legendFormat": "{{ service }} (circuit open)",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "Cache",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103
    },
    {
      "id": 9,
      "title": "Session Cache Hit Ratio",
      "description": "Ratio of cache hits to total lookups. Low ratio means most sessions fall through to DB.",
      "type": "gauge",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true,
        "showThresholdLabels": false
      },
      "targets": [
        {
          "expr": "rate(asibot_session_cache_hits_total[5m]) / (rate(asibot_session_cache_hits_total[5m]) + rate(asibot_session_cache_misses_total[5m]))",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Session Cache Hits vs Misses",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 30,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "hits" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "misses" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "calcs": ["mean"] }
      },
      "targets": [
        {
          "expr": "rate(asibot_session_cache_hits_total[5m])",
          "legendFormat": "hits",
          "refId": "A"
        },
        {
          "expr": "rate(asibot_session_cache_misses_total[5m])",
          "legendFormat": "misses",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "title": "Cache Miss Rate",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "rate(asibot_session_cache_misses_total[5m])",
          "legendFormat": "misses/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "System",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 104
    },
    {
      "id": 12,
      "title": "HTTP Connection Pool Utilization",
      "description": "Number of pooled httpx clients in the connection pool (max 200)",
      "type": "gauge",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 200,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 190 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "asibot_requests_total",
          "legendFormat": "Note: use /health JSON pool_size for live count. This panel tracks total request volume as a proxy.",
          "refId": "A",
          "hide": true
        },
        {
          "expr": "sum(rate(asibot_requests_total[5m])) by (service)",
          "legendFormat": "{{ service }} req/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "title": "Audit Write Failures",
      "description": "Track audit log write failures via error-status tool calls to the 'system' service. Sustained failures may indicate disk full or DB issues.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "expr": "sum(rate(asibot_requests_total{service=\"system\", status=\"error\"}[5m]))",
          "legendFormat": "system errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "Request Volume Heatmap",
      "description": "Distribution of request durations over time",
      "type": "heatmap",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": {
          "scheme": "Oranges",
          "mode": "scheme"
        },
        "cellGap": 1,
        "tooltip": { "show": true }
      },
      "targets": [
        {
          "expr": "sum(increase(asibot_request_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le)",
          "legendFormat": "{{ le }}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
